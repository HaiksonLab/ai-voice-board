<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_menu"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- Paste last text  +  History action on the right -->
    <LinearLayout
        android:id="@+id/itemMicPaste"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="6dp"
        android:background="@drawable/bg_menu_item"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_paste"
            android:scaleType="fitCenter"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="@string/menu_paste_last"
            android:textColor="#E5E7EB"
            android:textSize="14sp"
            android:includeFontPadding="false" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:id="@+id/historyDivider"
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="2dp"
            android:background="@drawable/divider_menu" />

        <ImageView
            android:id="@+id/btnHistory"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="7dp"
            android:src="@drawable/ic_history"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_menu_item"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="History" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:background="@drawable/divider_menu" />

    <!-- Retry last recording -->
    <LinearLayout
        android:id="@+id/itemMicRetry"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:background="@drawable/bg_menu_item"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_retry"
            android:scaleType="fitCenter"
            android:alpha="0.7" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="12dp"
            android:text="@string/menu_retry"
            android:textColor="#E5E7EB"
            android:textSize="14sp"
            android:includeFontPadding="false" />
    </LinearLayout>

</LinearLayout>
